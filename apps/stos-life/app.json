{
  "expo": {
    "name": "STOS Life",
    "slug": "stos-life",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "stos-life",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stos.life"
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3066"
    },
    "android": {
      "package": "com.stos.life",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3066"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-location",
      "expo-camera",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "498d3d55-e61f-4d53-9891-27e92dd9c5cc"
      }
    }
  }
}
