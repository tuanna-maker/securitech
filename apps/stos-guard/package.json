{
  "name": "stos-guard",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prestart": "node scripts/check-node.mjs",
    "preios": "node scripts/check-node.mjs",
    "start": "expo start",
    "ios": "expo run:ios",
    "ios:install": "expo run:ios",
    "android": "expo run:android",
    "build:apk": "eas build --platform android --profile preview --non-interactive",
    "build:apk:local": "eas build --platform android --profile preview --local",
    "build:cloud:android": "eas build --platform android --profile preview --non-interactive",
    "build:cloud:ios-sim": "eas build --platform ios --profile preview-simulator --non-interactive"
  },
  "dependencies": {
    "@stos/mobile-shared": "file:../../packages/mobile-shared",
    "@expo-google-fonts/be-vietnam-pro": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
