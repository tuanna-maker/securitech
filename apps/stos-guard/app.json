{
  "expo": {
    "name": "STOS Guard",
    "slug": "stos-guard",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "stos-guard",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stos.guard"
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3066"
    },
    "android": {
      "package": "com.stos.guard",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F58220"
      }
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-font", "expo-location", "expo-camera", "expo-notifications"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
